{
  "name": "@nmnmcc/ability",
  "version": "0.1.0",
  "description": "An Effect-style authorization library backed by CASL.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "yarn@4.14.1",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nmnmcc/ability.git"
  },
  "bugs": {
    "url": "https://github.com/nmnmcc/ability/issues"
  },
  "homepage": "https://github.com/nmnmcc/ability#readme",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./Ability": {
      "types": "./dist/Ability.d.ts",
      "import": "./dist/Ability.js",
      "default": "./dist/Ability.js"
    },
    "./AbilityExtra": {
      "types": "./dist/AbilityExtra.d.ts",
      "import": "./dist/AbilityExtra.js",
      "default": "./dist/AbilityExtra.js"
    },
    "./Casl": {
      "types": "./dist/Casl.d.ts",
      "import": "./dist/Casl.js",
      "default": "./dist/Casl.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "prepack": "yarn build",
    "prepublishOnly": "yarn typecheck && yarn test",
    "release:check": "yarn typecheck && yarn test && yarn pack --dry-run",
    "format": "prettier . -w",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "npm": "YARN_NPM_REGISTRY_SERVER=https://registry.npmjs.org yarn npm"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "devDependencies": {
    "@effect/language-service": "^0.85.1",
    "@effect/vitest": "4.0.0-beta.59",
    "@types/node": "^25.6.0",
    "effect": "^4.0.0-beta.59",
    "prettier": "^3.8.3",
    "tsdown": "^0.21.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "4.1.4"
  },
  "peerDependencies": {
    "effect": "^4.0.0-beta.59"
  },
  "dependencies": {
    "@casl/ability": "^6.8.1"
  }
}
